# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=campus_eye
POSTGRES_PASSWORD=campus_eye_secret
POSTGRES_DB=campus_eye
# Use localhost because PostgreSQL runs in Docker but exposes port 5432 to host
DATABASE_URL=postgresql+asyncpg://campus_eye:campus_eye_secret@localhost:5432/campus_eye

# ── Redis / Celery ────────────────────────────────────────────────────────────
# Redis also runs in Docker and exposes port 6379 to host
REDIS_URL=redis://localhost:6379/0

# ── Email Alerts (SMTP) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_TO=security@campus.edu

# ── Discord Webhook ───────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ── Camera / Video Source ─────────────────────────────────────────────────────
# Set to a file path for testing: /app/media/test_video.mp4
CAMERA_URL=rtsp://username:password@192.168.1.100:554/stream1

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=changeme_use_a_long_random_string
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# ── Detection ─────────────────────────────────────────────────────────────────
PROCESS_FPS=5
FACE_RECOGNITION_THRESHOLD=0.5
LOITERING_THRESHOLD_SECONDS=30
